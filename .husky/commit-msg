#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# Enforce conventional commit message format
# Format: <type>(scope): <subject>
# Types: feat, fix, docs, style, refactor, test, chore, build, ci

commit_msg=$(cat "$1")
pattern="^(feat|fix|docs|style|refactor|test|chore|build|ci)(\(.+\))?: .{1,100}$"

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo "❌ Invalid commit message format."
  echo ""
  echo "   Expected: <type>(scope): <subject>"
  echo "   Example:  feat(content): add DOM selector fallback strategy"
  echo ""
  echo "   Allowed types: feat, fix, docs, style, refactor, test, chore, build, ci"
  echo "   Your message: $commit_msg"
  exit 1
fi

echo "✅ Commit message format OK"
